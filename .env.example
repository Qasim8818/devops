# DevSecOps Agent Configuration

# AI/LLM Config
OLLAMA_API_URL=http://localhost:11434
LLM_MODEL=llama2  # or your preferred model
LLM_TIMEOUT=30

# API Config
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
DEBUG=false

# Monitoring Config
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
LOKI_URL=http://loki:3100

# Alerting Config
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_EMAIL_FROM=alerts@yourdomain.com
ALERT_EMAIL_PASSWORD=your_app_password

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database (optional if using persisted storage)
# DB_URL=postgresql://user:pass@localhost/devsecops

# Feature Flags
ENABLE_AUTO_REMEDIATION=true
ENABLE_SLACK_INTEGRATION=false
ENABLE_CVE_SCANNER=false
ENABLE_COST_ANOMALY_DETECTION=false
