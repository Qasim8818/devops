## 🔧 FIX 2: Real Async SQLAlchemy Routes

**NEW `backend/routes/incidents.py`** (complete replacement):

```python
"""
Incident Routes - FULL Async SQLAlchemy Implementation
"""
from fastapi import APIRouter, HTTPException, Query, Depends
from typing import Dict, Any, List
from datetime import datetime, timedelta
from sqlalchemy import select, desc, and_
from sqlalchemy.ext.asyncio import AsyncSession

from database import Incident, get_session

router = APIRouter()

def serialize_incident(incident: Incident) -> Dict[str, Any]:
    """Serialize Incident to dict (exclude private attrs)"""
    data = dict(incident.__dict__)
    data.pop('_sa_instance_state', None)
    return data

@router.get("")
async def list_incidents(
    status: str = Query(None),
    severity: str = Query(None),
    limit: int = Query(100, le=1000),
    session: AsyncSession = Depends(get_session)
) -> List[Dict[str, Any]]:
    """List incidents with async SQLAlchemy filters"""
    query = select(Incident).order_by(desc(Incident.created_at)).limit(limit)
    if status:
        query = query.where(Incident.status == status)
    if severity:
        query = query.where(Incident.severity == severity)
    
    async with session.begin():
        result = await session.execute(query)
        incidents = result.scalars().all()
    return [serialize_incident(i) for i in incidents]

@router.get("/{incident_id}")
async def get_incident(
    incident_id: str,
    session: AsyncSession = Depends(get_session)
) -> Dict[str, Any]:
    """Get single incident"""
    async with session.begin():
        incident = await session.get(Incident, incident_id)
        if not incident:
            raise HTTPException(404, "Incident not found")
    return serialize_incident(incident)

@router.get("/{incident_id}/timeline")
async def get_incident_timeline(
    incident_id: str,
    limit: int = Query(50),
    session: AsyncSession = Depends(get_session)
) -> List[Dict[str, Any]]:
    """Timeline via AuditLog (placeholder query until AuditLog.incident_id added)"""
    # TODO: Add incident_id to AuditLog model for join
    return [{"timestamp": datetime.utcnow().isoformat(), "event": f"Timeline for {incident_id}"}]
```

**NEW `backend/routes/remediation.py`** (complete replacement):

```python
"""
Remediation Routes - FULL Async SQLAlchemy
"""
from fastapi import APIRouter, HTTPException, Depends, Query
from typing import Dict, Any, List
from datetime import datetime
from pydantic import BaseModel
from sqlalchemy import select, desc, func
from sqlalchemy.ext.asyncio import AsyncSession

from database import RemediationRule, AuditLog, Incident, get_session

router = APIRouter()

class RemediationRequest(BaseModel):
    incident_id: str
    action: str
    dry_run: bool = True

def serialize_rule(rule: RemediationRule) -> Dict[str, Any]:
    return {k: v for k, v in rule.__dict__.items() if not k.startswith('_')}

@router.get("/rules")
async def list_remediation_rules(
    enabled: bool = True,
    session: AsyncSession = Depends(get_session)
) -> List[Dict[str, Any]]:
    """Active remediation rules"""
    query = select(RemediationRule).where(RemediationRule.enabled == enabled).order_by(RemediationRule.priority)
    async with session.begin():
        result = await session.execute(query)
        rules = result.scalars().all()
    return [serialize_rule(r) for r in rules]

@router.post("/execute")
async def execute_remediation(
    request: RemediationRequest,
    session: AsyncSession = Depends(get_session)
) -> Dict[str, Any]:
    """Execute + log remediation"""
    if request.dry_run:
        return {
            "status": "dry_run_success",
            "incident_id": request.incident_id,
            "action": request.action,
            "timestamp": datetime.utcnow().isoformat()
        }
    
    # Log action
    audit = AuditLog(
        action=f"remediation:{request.action}",
        resource_type="incident",
        resource_id=request.incident_id,
        status="executing",
        details={"action": request.action}
    )
    session.add(audit)
    await session.flush()
    
    # Update incident
    inc = await session.get(Incident, request.incident_id)
    if inc:
        inc.remediation_action = request.action
        inc.remediation_status = "running"
    
    await session.commit()
    
    return {"status": "executing", "audit_id": audit.id}

@router.get("/history")
async def remediation_history(
    limit: int = Query(50),
    session: AsyncSession = Depends(get_session)
) -> List[Dict[str, Any]]:
    """Remediation history from AuditLog"""
    query = select(AuditLog).where(
        AuditLog.action.like("remediation:%")
    ).order_by(desc(AuditLog.created_at)).limit(limit)
    async with session.begin():
        result = await session.execute(query)
        logs = result.scalars().all()
    return [serialize_rule(log) for log in logs]  # Reuse serialize (generic)
```

